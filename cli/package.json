{
  "name": "deweyou-cli",
  "version": "0.2.0",
  "type": "module",
  "description": "Dewey's personal agent workflow bootstrapper",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "bin": {
    "deweyou-cli": "./dist/deweyou.mjs"
  },
  "scripts": {
    "build": "vp pack src/bin/deweyou.ts --out-dir dist --clean",
    "prepare": "npm run build",
    "release:prepare": "tsx scripts/prepare-release.ts",
    "test": "vp test run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/bin/deweyou.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "4.1.5",
    "typescript": "^6.0.2",
    "tsx": "^4.21.0",
    "vitest": "4.1.5",
    "vite-plus": "^0.1.21"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
