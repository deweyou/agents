{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node", "vitest"]
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "vite.config.ts"]
}
